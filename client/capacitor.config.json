{
  "appId": "com.orgagym.app",
  "appName": "OrgaGym",
  "webDir": "dist",
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#141414",
    "scrollEnabled": false,
    "allowsInlineMediaPlayback": true
  },
  "plugins": {
    "Keyboard": {
      "resize": "none"
    },
    "StatusBar": {
      "style": "DARK",
      "overlaysWebView": true
    }
  }
}
