{
  "appId": "com.orgagym.app",
  "appName": "OrgaGym",
  "webDir": "dist",
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#0E0E0E",
    "scrollEnabled": false,
    "allowsInlineMediaPlayback": true
  },
  "plugins": {
    "Keyboard": {
      "resize": "body"
    },
    "StatusBar": {
      "style": "DARK",
      "overlaysWebView": true
    }
  }
}
